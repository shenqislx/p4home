menu "P4Home Network Service"

config P4HOME_WIFI_SSID
    string "Wi-Fi SSID"
    default ""

config P4HOME_WIFI_PASSWORD
    string "Wi-Fi password"
    default ""

config P4HOME_WIFI_MAX_RETRY
    int "Fast retry count before slow retry"
    range 0 32
    default 5

config P4HOME_WIFI_AUTOSTART
    bool "Autostart Wi-Fi station on boot"
    default y

config P4HOME_WIFI_VERIFY_WAIT_MS
    int "Startup Wi-Fi verify wait (ms)"
    range 0 60000
    default 3000

endmenu

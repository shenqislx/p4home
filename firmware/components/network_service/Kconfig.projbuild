menu "P4Home Network Service"

config P4HOME_WIFI_SSID
    string "Wi-Fi SSID"
    default ""

config P4HOME_WIFI_PASSWORD
    string "Wi-Fi password"
    default ""

config P4HOME_WIFI_MAX_RETRY
    int "Fast retry count before slow retry"
    range 0 32
    default 5

config P4HOME_WIFI_AUTOSTART
    bool "Autostart Wi-Fi station on boot"
    default y

config P4HOME_WIFI_VERIFY_WAIT_MS
    int "Startup Wi-Fi verify wait (ms)"
    range 0 60000
    default 3000

config P4HOME_WIFI_STATIC_IP_ENABLE
    bool "Enable static IPv4 for Wi-Fi STA debug"
    default n

if P4HOME_WIFI_STATIC_IP_ENABLE

config P4HOME_WIFI_STATIC_IP_ADDR
    string "Static IPv4 address"
    default "192.168.1.50"

config P4HOME_WIFI_STATIC_IP_NETMASK
    string "Static IPv4 netmask"
    default "255.255.255.0"

config P4HOME_WIFI_STATIC_IP_GATEWAY
    string "Static IPv4 gateway"
    default "192.168.1.1"

config P4HOME_WIFI_STATIC_IP_DNS1
    string "Static IPv4 primary DNS"
    default "192.168.1.1"

config P4HOME_WIFI_STATIC_IP_DNS2
    string "Static IPv4 secondary DNS"
    default "8.8.8.8"

endif

endmenu
